---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Academic Profile | Linkaili" sideBarActiveItemID="cv">

  <!-- Education Section -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold font-serif">Education</div>
  </div>

  <div class="mb-10">
    <div class="bg-base-200 p-6 rounded-xl">
      <h3 class="text-xl font-bold mb-2">Portola High School</h3>
      <p class="text-sm opacity-75">Irvine, CA, USA · Expected Graduation: 2027</p>
    </div>
  </div>

  <!-- Honors & Awards -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold font-serif">Honors & Awards</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="CIF Division II Team Champion — Girls Golf"
      subtitle="2024–25 & 2025–26 — Portola High School"
    >
      Member of the Portola High School girls golf team that won the CIF Division II
      championship in two consecutive school years (2024–25 and 2025–26).
    </TimeLineElement>
  </div>

  <!-- Athletics Section -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold font-serif">Athletic Profile (Golf & Badminton)</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Girls Golf Team — Three-Year Member"
      subtitle="2023 – Present — Portola High School"
    >
      Committed member of the girls golf team for all three years of high school.
      The team won back-to-back CIF Division II championships (2024–25, 2025–26).
    </TimeLineElement>
    <TimeLineElement
      title="Badminton Club — Treasurer & Founding Member; No. 1 Girls' Player"
      subtitle="Portola High School"
    >
      <ul class="list-disc ml-5">
        <li>Treasurer of the school's badminton club.</li>
        <li>Helped create and launch the school's badminton team.</li>
        <li>Team has competed in CIF tournament play and CIF school matches.</li>
        <li>Currently the top-ranked girls' player on the team.</li>
      </ul>
    </TimeLineElement>
  </div>

  <!-- Leadership & Service -->
  <div class="mb-5">
    <div class="text-3xl w-full font-bold font-serif">Leadership & Service</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Founder — Dragon & Lion Dance Club"
      subtitle="Approved · Launching next school year — Portola High School"
    >
      Proposed and founded a school dragon & lion dance club so students can learn about
      this Chinese martial-art tradition and try it themselves. The club has been
      officially approved and will begin next school year.
    </TimeLineElement>
    <TimeLineElement
      title="Volunteer, Kids Buddy — Mariners Church"
    >
      Supports children with special needs, helping them feel a sense of belonging and joy.
    </TimeLineElement>
    <TimeLineElement
      title="Assistant Badminton Coach — Pureking Program"
    >
      Volunteer assistant coach for Pureking badminton, a government-created community program.
    </TimeLineElement>
    <TimeLineElement
      title="Dragon Dance Performer — Irvine Chinese School"
    >
      Volunteer dragon dancer; practices weekly toward the school's annual performance at the
      Segerstrom Center for the Arts, sharing Chinese culture with the wider community.
    </TimeLineElement>
  </div>

</BaseLayout>
