---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1 font-serif italic text-gray-500" data-i18n="home-biography-label">Biography</div>
    <div class="text-5xl font-bold font-serif mb-4" data-i18n="home-name">Linkaili</div>
    <div class="text-2xl py-2 font-light text-base-content/80" data-i18n="home-subtitle">
      Student-Athlete (Golf & Badminton) & Community Leader | Class of 2027
    </div>

    <div class="py-6 text-lg leading-relaxed text-justify">
      <p class="mb-4" data-i18n="home-bio1">
        Linkaili is a high school student at <strong>Portola High School</strong> in Irvine, California (Class of 2027). She is a three-year member of the girls golf team—<strong>back-to-back CIF Division II champions</strong> (2024–25 and 2025–26)—and the top girls' player and treasurer of the badminton club she helped found.
      </p>
      <p data-i18n="home-bio2">
        Beyond competition, she leads and serves: a kids' buddy for children with special needs at Mariners Church, an assistant badminton coach for the Pureking community program, and a dragon dancer at Irvine Chinese School. She founded her school's <strong>Dragon &amp; Lion Dance Club</strong> to share Chinese culture—approved to launch next school year.
      </p>
    </div>

    <div class="mt-4 flex gap-4">
      <a class="btn btn-primary" href="/cv" data-i18n="home-view-profile">View Academic Profile</a>
      <a class="btn btn-outline" href="mailto:linkaili.2008@gmail.com" data-i18n="home-contact-admissions">Contact for Admissions</a>
    </div>
  </div>

  <div class="divider my-10"></div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 font-serif" data-i18n="home-research-title">Research & Leadership Highlights</div>
  </div>

  <div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
    <a href="/cv" target="_blank">
      <div class="hero-content flex-col md:flex-row">
        <img src="/golf_match.jpg" alt="Varsity Golf Leadership" class="max-w-full md:max-w-[13rem] rounded-lg" />
        <div class="grow w-full">
          <h1 class="text-xl font-bold">
            <span data-i18n="home-golf-title">CIF Division II Champion — Girls Golf</span>
            <div class="badge badge-secondary mx-2">Athletics</div>
          </h1>
          <p class="py-1 text-1xl" data-i18n="home-golf-desc">Three-year member of Portola High School's girls golf team — back-to-back CIF Division II champions (2024–25 and 2025–26).</p>
        </div>
      </div>
    </a>
  </div>
  <div class="divider my-0"></div>
  <div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
    <a href="/cv" target="_blank">
      <div class="hero-content flex-col md:flex-row">
        <img src="/volunteering.jpg" alt="Leadership, Culture & Service" class="max-w-full md:max-w-[13rem] rounded-lg" />
        <div class="grow w-full">
          <h1 class="text-xl font-bold">
            <span data-i18n="home-env-title">Leadership, Culture & Service</span>
            <div class="badge badge-secondary mx-2">Leadership</div>
          </h1>
          <p class="py-1 text-1xl" data-i18n="home-env-desc">Founder of the school's Dragon & Lion Dance Club, badminton club treasurer, and a volunteer at Mariners Church, Pureking, and Irvine Chinese School.</p>
        </div>
      </div>
    </a>
  </div>

  <div class="divider my-0"></div>
  <div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
    <a href="/projects/smart-dog-en" target="_self">
      <div class="hero-content flex-col md:flex-row">
        <img src="/itemPreview.webp" alt="Robotics Engineering: Voice Dog" class="max-w-full md:max-w-[13rem] rounded-lg" />
        <div class="grow w-full">
          <h1 class="text-xl font-bold">
            <span data-i18n="home-robotics-title">Robotics Engineering — Voice Dog</span>
            <div class="badge badge-secondary mx-2">Robotics</div>
          </h1>
          <p class="py-1 text-1xl" data-i18n="home-robotics-desc">
            A continuing robotics project family, starting with a Petoi Bittle X V2 voice dog that turns spoken commands into expressive actions.
          </p>
        </div>
      </div>
    </a>
  </div>

  <div class="divider my-10"></div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 font-serif" data-i18n="home-essays-title">Selected Essays</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img="/volunteering.jpg" 
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
