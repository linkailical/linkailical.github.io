---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<BaseLayout title="Research & Projects | Linkaili" sideBarActiveItemID="projects">

  <div class="mb-8">
    <div class="text-3xl w-full font-bold font-serif mb-2">Research & Projects</div>
    <div class="text-lg opacity-80">
      Working at the intersection of Health, Education, and Robotics — using data and
      technology to tackle real problems.
    </div>
  </div>

  <div class="divider text-xl font-bold">Project Families</div>

  <div class="grid gap-4 md:grid-cols-2 mb-8">
    <a href="/robotics/" class="block rounded-lg border border-base-300 bg-base-100 p-5 hover:shadow-lg transition">
      <div class="badge badge-secondary mb-3">Robotics Engineering</div>
      <div class="text-xl font-bold mb-2">Robotics: Voice Dog</div>
      <p class="opacity-80">
        A growing robotics collection. The first implementation uses Petoi Bittle X V2
        to translate voice commands into expressive motion.
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        <span class="badge badge-outline">Voice control</span>
        <span class="badge badge-outline">BiBoard / ESP32</span>
        <span class="badge badge-outline">Expressive actions</span>
      </div>
    </a>

    <a href="/aidoctor/" class="block rounded-lg border border-base-300 bg-base-100 p-5 hover:shadow-lg transition">
      <div class="badge badge-secondary mb-3">Health Technology</div>
      <div class="text-xl font-bold mb-2">Medical AI Tools</div>
      <p class="opacity-80">
        Browser-based health demos, including a B-ultrasound annotation workflow
        and a rule-based AI Doctor symptom checker.
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        <span class="badge badge-outline">Medical imaging</span>
        <span class="badge badge-outline">Data annotation</span>
        <span class="badge badge-outline">Symptom triage</span>
      </div>
    </a>
  </div>

  <div class="divider text-xl font-bold">Featured Projects</div>

  <!-- Language toggle for project cards (mirrors the Notes page behaviour) -->
  <style is:inline>
    .project-item[data-lang="zh"] { display: none; }
  </style>
  <script is:inline>
    (function () {
      const lang = localStorage.getItem("language");
      if (lang === "zh") {
        document.write(
          '<style>.project-item[data-lang="en"]{display:none}.project-item[data-lang="zh"]{display:block}</style>'
        );
      }
    })();
  </script>

  {
    projects.map((project) => (
      <div class="project-item" data-lang={project.data.lang || "en"}>
        <HorizontalCard
          title={project.data.title}
          img={project.data.heroImage}
          desc={project.data.description}
          url={"/projects/" + project.slug}
          target="_self"
          badge={project.data.badge}
          tags={project.data.tags}
        />
        <div class="divider my-0" />
      </div>
    ))
  }

  <div class="divider text-xl font-bold mt-10">Independent Research</div>

  <HorizontalCard
    title="Paper: Sustainable Course Management"
    img="/study.jpg"
    desc="ABSTRACT: This research investigates water conservation techniques in local golf courses. METHODOLOGY: Conducted field surveys and interviewed course superintendents. RESULTS: Proposed a new irrigation schedule that could reduce water usage by 15%."
    url="#"
    badge="Environmental Science"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Data Analysis: Golf Swing Biomechanics"
    img="/golf_match.jpg"
    desc="Using high-speed camera data to analyze the kinematic sequence of the golf swing. Applied physics principles to optimize torque and reduce injury risk."
    url="#"
    badge="Physics / Kinesiology"
  />

  <div class="divider text-xl font-bold mt-10">Leadership Projects</div>

  <HorizontalCard
    title="Community Junior Golf Clinic"
    img="/volunteering.jpg"
    desc="Founded a weekend workshop introducing golf basics to underprivileged children. Created a scalable curriculum and recruited 5 student coaches."
    url="#"
    badge="Service Leadership"
  />

</BaseLayout>
